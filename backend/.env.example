# Optional: outbound webhook for leader engagement automations.
# When unset, the webhook layer is disabled and nothing is dispatched.
# ENGAGEMENT_WEBHOOK_URL="https://hooks.example.com/leaders"
# ENGAGEMENT_WEBHOOK_TIMEOUT_MS=5000

# Static token for the /automation/* endpoints (n8n crons). Generate a long
# random string. When unset, those endpoints only accept a coordinator JWT.
# AUTOMATION_API_TOKEN="troque_por_um_token_longo_e_aleatorio"

# Public URL of the frontend, used to build absolute confirmation links in
# automation payloads (event reminders).
# APP_PUBLIC_URL="https://redeguti.ddnsfree.com"

# ── Instance parameters (multi-instance / Phase A) ───────────────────────────
# Municipalities dataset validated on public signup. 'sp' maps to
# src/data/municipios_sp_645.csv; any other value <name> loads
# src/data/municipios_<name>.csv (same CSV layout: header + "code,name" rows).
# GEO_DATASET="sp"
# State code stamped on municipalities created by the app.
# GEO_STATE_CODE="SP"
# Set to "false" on instances that do not collect the "igreja" field on
# supporter registration (region-based verticals). Supporters are then linked
# to the sentinel church record "(sem igreja)".
# CHURCH_FIELD_ENABLED="true"
