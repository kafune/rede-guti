// Prisma schema for Rede Evangelica SP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  COORDENADOR
  LIDER_REGIONAL
  VERIFICADORA
}

enum IndicationStatus {
  ATIVO
  INATIVO
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  name               String?      @map("name")
  devzappLink        String?      @map("devzapp_link")
  passwordHash       String       @map("password_hash")
  role               Role         @default(LIDER_REGIONAL)
  indicatedByUserId  String?      @map("indicated_by_user_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  indicatedByUser    User?        @relation("UserIndications", fields: [indicatedByUserId], references: [id], onDelete: SetNull)
  indicatedUsers     User[]       @relation("UserIndications")
  createdIndications Indication[] @relation("CreatedBy")
  indicatedSupporters Indication[] @relation("IndicatedByUser")
  eventoIndicacoes EventoIndicado[] @relation("LiderEventoIndicados")

  @@index([role])
  @@index([indicatedByUserId])
  @@map("users")
}

model AppConfig {
  id                String   @id @default("default")
  whatsappGroupLink String?  @map("whatsapp_group_link")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model Church {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at")
  indications Indication[]

  @@map("churches")
}

model Municipality {
  id        String       @id @default(cuid())
  name      String
  stateCode String       @default("SP") @map("state_code")
  createdAt DateTime     @default(now()) @map("created_at")
  indications Indication[]

  @@unique([name, stateCode])
  @@map("municipalities")
}

enum EventoIndicadoStatus {
  INDICADO
  APROVADO
  RECUSADO
  PRESENTE
}

model Evento {
  id             String           @id @default(cuid())
  nome           String
  data           DateTime
  hora           String
  local          String
  limitePorLider Int              @default(0) @map("limite_por_lider")
  observacao     String?
  encerrado      Boolean          @default(false)
  createdAt      DateTime         @default(now()) @map("created_at")
  indicados      EventoIndicado[]

  @@map("eventos")
}

model EventoIndicado {
  id        String               @id @default(cuid())
  eventoId  String               @map("evento_id")
  nome      String
  telefone  String
  liderId   String               @map("lider_id")
  status    EventoIndicadoStatus @default(INDICADO)
  createdAt DateTime             @default(now()) @map("created_at")
  evento    Evento               @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  lider     User                 @relation("LiderEventoIndicados", fields: [liderId], references: [id])

  @@unique([eventoId, telefone])
  @@index([eventoId])
  @@index([liderId])
  @@map("evento_indicados")
}

model Indication {
  id                String       @id @default(cuid())
  name              String
  phone             String?
  email             String?
  status            IndicationStatus @default(ATIVO)
  indicatedBy       String?      @map("indicated_by")
  indicatedByUserId String?      @map("indicated_by_user_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  createdById       String       @map("created_by_id")
  churchId          String       @map("church_id")
  municipalityId    String       @map("municipality_id")

  createdBy       User         @relation("CreatedBy", fields: [createdById], references: [id])
  indicatedByUser User?        @relation("IndicatedByUser", fields: [indicatedByUserId], references: [id], onDelete: SetNull)
  church          Church       @relation(fields: [churchId], references: [id])
  municipality    Municipality @relation(fields: [municipalityId], references: [id])

  @@index([createdAt])
  @@index([createdById])
  @@index([churchId])
  @@index([municipalityId])
  @@index([indicatedByUserId])
  @@map("indications")
}
